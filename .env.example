# ADMIN_PASSWORD: The password for the admin content editing interface.
# Default is "admin123" if not set.
ADMIN_PASSWORD="mysecretpassword"

# VITE_ADMIN_PASSWORD: The password used for client-side login on static deployments (Netlify).
# This MUST match ADMIN_PASSWORD if you want consistent behavior.
VITE_ADMIN_PASSWORD="mysecretpassword"

# GitHub Configuration for Content Saving (Optional)
# If these are set, clicking "Save" will commit changes directly to your repository.
# If not set, "Save" will download a JSON file for you to upload manually.
VITE_GITHUB_TOKEN="your_github_personal_access_token"
VITE_REPO_OWNER="your_github_username"
VITE_REPO_NAME="your_repo_name"
